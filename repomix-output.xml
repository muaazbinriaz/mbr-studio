<file path="app/globals.css">
@import "tailwindcss";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

/* ---------------------------------------------------------------------
   MBR Studio Design Tokens
   Source: Blueprint Part 1, Section 3 — UI/UX Design System
   The studio's brand is dark-first (near-black canvas, indigo primary),
   so the dark palette below is applied as the default theme.
--------------------------------------------------------------------- */
:root {
  /* Color System — LIGHT */
  --background: #eef0f7;
  --background-secondary: #e4e7f3;
  --card: #ffffff;
  --primary: #6366f1;
  --accent: #06b6d4;
  --success: #10b981;
  --warning: #f59e0b;
  --error: #ef4444;
  --foreground: #14141c;
  --muted-foreground: #62626f;
  --border: rgba(20, 20, 28, 0.1);

  --primary-foreground: #f9fafb;
  --secondary: var(--background-secondary);
  --secondary-foreground: #14141c;
  --muted: #e4e7f3;
  --accent-foreground: #f9fafb;
  --destructive: var(--error);
  --destructive-foreground: #f9fafb;
  --card-foreground: #14141c;
  --popover: var(--card);
  --popover-foreground: #14141c;
  --input: rgba(20, 20, 28, 0.14);
  --ring: var(--primary);

  --shadow-sm: 0 1px 2px rgba(20, 20, 28, 0.06);
  --shadow-md:
    0 4px 12px rgba(20, 20, 28, 0.08), 0 2px 4px rgba(20, 20, 28, 0.04);
  --shadow-lg:
    0 12px 32px rgba(20, 20, 28, 0.1), 0 4px 8px rgba(20, 20, 28, 0.05);

  /* Radius — 8px controls, 16px cards, 24px panels */
  --radius: 0.5rem;
  --radius-card: 1rem;
  --radius-panel: 1.5rem;

  /* 8-point spacing scale */
  --space-1: 8px;
  --space-2: 16px;
  --space-3: 24px;
  --space-4: 32px;
  --space-6: 48px;
  --space-8: 64px;
  --space-12: 96px;
  --space-16: 128px;
}

.dark {
  /* Color System — DARK (unchanged) */
  --background: #030712;
  --background-secondary: #0f172a;
  --card: #111827;
  --primary: #6366f1;
  --accent: #06b6d4;
  --success: #10b981;
  --warning: #f59e0b;
  --error: #ef4444;
  --foreground: #f9fafb;
  --muted-foreground: #94a3b8;
  --border: rgba(255, 255, 255, 0.08);

  --primary-foreground: #f9fafb;
  --secondary: var(--background-secondary);
  --secondary-foreground: #f9fafb;
  --muted: var(--card);
  --accent-foreground: #f9fafb;
  --destructive: var(--error);
  --destructive-foreground: #f9fafb;
  --card-foreground: #f9fafb;
  --popover: var(--card);
  --popover-foreground: #f9fafb;
  --input: rgba(255, 255, 255, 0.08);
  --ring: var(--primary);
}

@theme inline {
  /* Fonts */
  --font-sans: var(--font-inter);
  --font-heading: var(--font-geist);

  /* Type scale — 12 / 14 / 16 / 18 / 24 / 32 / 48 / 64 / 80px */
  --text-xs: 0.75rem; /* 12px */
  --text-sm: 0.875rem; /* 14px */
  --text-base: 1rem; /* 16px */
  --text-lg: 1.125rem; /* 18px */
  --text-xl: 1.5rem; /* 24px */
  --text-2xl: 2rem; /* 32px */
  --text-3xl: 3rem; /* 48px */
  --text-4xl: 4rem; /* 64px */
  --text-5xl: 5rem; /* 80px */

  /* Colors mapped for Tailwind utilities: bg-background, text-foreground,
     bg-primary, border-border, etc. */
  --color-background: var(--background);
  --color-background-secondary: var(--background-secondary);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-success: var(--success);
  --color-warning: var(--warning);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);

  /*
   * Alias tokens — bridge the gap between the token names declared above
   * and the class names actually used throughout the codebase
   * (text-text, text-secondary-text, bg-secondary-background). Without
   * these, Tailwind v4 silently generates no CSS for those classes since
   * no matching --color-* custom property exists, making them no-ops
   * across the entire site. Aliasing here (rather than renaming every
   * call site) keeps this a minimal, low-risk fix.
   */
  --color-text: var(--foreground);
  --color-secondary-text: var(--muted-foreground);
  --color-secondary-background: var(--background-secondary);

  /* Radius */
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: var(--radius-card);
  --radius-2xl: var(--radius-panel);
}

nav a {
  color: inherit;
}

@layer base {
  * {
    border-color: var(--color-border);
    outline-color: var(--color-ring);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--color-background);
    color: var(--color-foreground);
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: var(--text-base); /* 16px */
    line-height: 1.7; /* generous line-height for readability, per design system */
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ---------------------------------------------------------------
     Headings
     Geist, bold, tight letter-spacing, large scale.
     Mapped onto the 12/14/16/18/24/32/48/64/80px type scale, fluid
     between a mobile floor and the desktop value at the tablet
     breakpoint (768px). The hero headline (Section 7) intentionally
     overrides h1 locally with a bigger, page-specific size — these
     are the defaults for ordinary page/section headings.
  --------------------------------------------------------------------- */
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-heading), var(--font-sans), system-ui, sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-foreground);
  }

  h1 {
    font-size: 2.5rem; /* 40px mobile */
    font-weight: 800;
  }

  h2 {
    font-size: var(--text-2xl); /* 32px mobile */
  }

  h3 {
    font-size: var(--text-xl); /* 24px mobile */
    line-height: 1.25;
  }

  h4 {
    font-size: var(--text-lg); /* 18px */
    line-height: 1.3;
  }

  h5 {
    font-size: var(--text-base); /* 16px */
    font-weight: 600;
    line-height: 1.4;
  }

  h6 {
    font-size: var(--text-sm); /* 14px */
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
  }

  @media (min-width: 768px) {
    h1 {
      font-size: var(--text-4xl); /* 64px desktop */
    }

    h2 {
      font-size: var(--text-3xl); /* 48px desktop */
    }

    h3 {
      font-size: var(--text-2xl); /* 32px desktop */
    }

    h4 {
      font-size: var(--text-xl); /* 24px desktop */
    }

    h5 {
      font-size: var(--text-lg); /* 18px desktop */
    }

    h6 {
      font-size: var(--text-base); /* 16px desktop */
    }
  }

  /* ---------------------------------------------------------------
     Body text
  --------------------------------------------------------------------- */
  p {
    color: var(--color-foreground);
  }

  p + p {
    margin-top: var(--space-2); /* 16px */
  }

  small {
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
  }

  strong,
  b {
    font-weight: 600;
  }

  ::selection {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
  }

  /* ---------------------------------------------------------------
     Links
     No underline at rest (per "minimal, no decoration" philosophy);
     underline on hover/focus signals interactivity without adding
     visual noise everywhere else.
  --------------------------------------------------------------------- */
  a {
    color: var(--color-primary);
    text-decoration: none;
    text-underline-offset: 3px;
    transition:
      color 150ms ease,
      text-decoration-color 150ms ease;
  }

  a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  p a:hover,
  li a:hover {
    text-decoration: underline;
  }

  /* Body copy inside prose blocks should read as plain text links,
     underlined by default so they're identifiable inline. */
  p a,
  li a {
    text-decoration: underline;
    text-decoration-color: color-mix(
      in srgb,
      var(--color-primary) 40%,
      transparent
    );
  }

  p a:hover,
  li a:hover {
    text-decoration-color: var(--color-accent);
  }

  /* ---------------------------------------------------------------
     Lists
  --------------------------------------------------------------------- */
  ul,
  ol {
    padding-left: var(--space-3); /* 24px */
  }

  li + li {
    margin-top: var(--space-1); /* 8px */
  }

  /* ---------------------------------------------------------------
     Code
  --------------------------------------------------------------------- */
  code,
  pre {
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 0.9em;
  }

  code {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.4em;
  }

  /* Visible focus states — WCAG AA */
  :focus-visible {
    outline: 2px solid var(--color-ring);
    outline-offset: 2px;
  }

  button:not(:disabled) {
    cursor: pointer;
  }
}

/* Site-wide scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  /* Was: hardcoded rgba(148, 163, 184, 0.3), which is dark mode's
     --muted-foreground value baked in literally — so the scrollbar
     stayed dark-gray even in light mode. Now correctly theme-reactive. */
  background-color: color-mix(
    in srgb,
    var(--color-secondary-text) 30%,
    transparent
  );
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background-color: color-mix(
    in srgb,
    var(--color-secondary-text) 50%,
    transparent
  );
}

/* Firefox */
* {
  scrollbar-width: thin;
  scrollbar-color: color-mix(
      in srgb,
      var(--color-secondary-text) 30%,
      transparent
    )
    transparent;
}

/* Chatbot panel scrollbar (already covered by site-wide, but can be more specific) */
#mbr-chat-panel ::-webkit-scrollbar-thumb {
  /* Was: hardcoded rgba(99, 102, 241, 0.4), a literal duplicate of
     --primary's hex value. Now sourced from the token directly. */
  background-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
}
