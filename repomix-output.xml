          >
            {option.label}
          </Link>
        ) : (
          <button
            key={option.id}
            type="button"
            onClick={() => onSelect(option)}
            className="rounded-full border border-border bg-background px-3.5 py-2 font-body text-sm text-text transition-colors duration-200 hover:border-primary hover:text-primary"
          >
            {option.label}
          </button>
        ),
      )}
    </div>
  );
}
