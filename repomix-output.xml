        <div className="min-h-0 flex-1 overflow-y-auto p-5">
          {tab === "manual" && <ManualTab onDone={onClose} />}
          {tab === "url" && <UrlTab onDone={onClose} />}
          {tab === "pdf" && <PdfTab onDone={onClose} />}
