        backgroundImage:
          "radial-gradient(circle at 15% 15%, rgba(99,102,241,0.25), transparent 55%), radial-gradient(circle at 85% 85%, rgba(6,182,212,0.2), transparent 55%)",
      }}
    >
      <div
        style={{
          display: "flex",
          alignItems: "center",
          gap: 16,
          marginBottom: 40,
        }}
