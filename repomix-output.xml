      .from("agents")
      .select("id")
      .eq("organization_id", membership.organization_id)
      .eq("is_active", true)
      .limit(1)
      .maybeSingle();

    agentId = agent?.id ?? null;

    if (agentId) {
      const { data: gr } = await supabase
